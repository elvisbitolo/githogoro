generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────

enum UserRole {
  resident
  business
  admin
}

enum ProfileRole {
  resident
  business
  admin
}

enum ChatRoomType {
  neighborhood
  group
  direct
}

enum AlertType {
  emergency
  general
}

enum JobType {
  fulltime
  parttime
  casual
  contract
  internship
}

enum CommunityPlaceCategory {
  school
  religious
  health
  transport
  market
  sports
  government
  water
  community
  emergency
  business
}

enum MessageType {
  text
  image
  voice
  location
  poll
  system
}

enum DisappearingDuration {
  off
  h24
  d7
  d30
}

enum PollStatus {
  active
  closed
}

enum BundleProvider {
  safaricom
  airtel
  telkom
  other
}

enum BundleCategory {
  daily
  weekly
  monthly
  hourly
  other
}

enum MarketplaceCategory {
  electronics
  furniture
  clothing
  food
  vehicles
  services
  other
}

enum MarketplaceItemStatus {
  available
  sold
  reserved
}

enum LostFoundType {
  lost
  found
}

enum LostFoundStatus {
  active
  resolved
}

enum EventRSVPStatus {
  going
  maybe
  not_going
}

enum ReputationAction {
  message_sent
  job_posted
  event_organized
  place_reported
  bundle_shared
  business_listed
  review_given
  poll_created
  poll_voted
  video_uploaded
  video_liked
  comment_added
  post_created
  post_liked
  skill_posted
  harambee_donated
}

enum PostPrivacy {
  public
  neighbors
  private
}

enum ReactionType {
  like
  love
  wow
  sad
  angry
  haha
}

enum NotificationType {
  like_post
  comment_post
  share_post
  follow
  harambee_donation
  harambee_update
  tontine_reminder
  loan_request
  loan_repayment
  errand_request
  errand_accepted
  event_invite
  event_rsvp
  skill_hired
  complaint_update
  volunteer_call
  petition_signature
  birthday
  obituary
  announcement
  mention
  message
  general
}

enum FundraiserStatus {
  active
  funded
  closed
  cancelled
}

enum TontineStatus {
  active
  completed
  paused
}

enum LoanStatus {
  pending
  active
  repaid
  defaulted
}

enum ErrandStatus {
  open
  accepted
  in_progress
  completed
  cancelled
}

enum RideStatus {
  scheduled
  full
  completed
  cancelled
}

enum ComplaintStatus {
  open
  acknowledged
  in_progress
  resolved
  dismissed
}

enum PetitionStatus {
  active
  achieved
  closed
}

enum MissingStatus {
  active
  found
}

enum SkillAvailability {
  available
  busy
  unavailable
}

// ─── Models ───────────────────────────────────────────

model Profile {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  phone            String
  zone             String?
  avatarUrl        String?  @map("avatar_url")
  coverUrl         String?  @map("cover_url")
  bio              String?
  dateOfBirth      DateTime? @map("date_of_birth")
  role             ProfileRole @default(resident)
  reputationScore  Int      @default(0) @map("reputation_score")
  reputationPoints Int      @default(0) @map("reputation_points")
  badges           Json     @default("[]")
  isVerified       Boolean  @default(false) @map("is_verified")
  createdAt        DateTime @default(now()) @map("created_at")
  lastSeen         DateTime? @map("last_seen")
  lastActiveAt     DateTime? @map("last_active_at")

  // Chat Relations
  chatRooms                    ChatRoom[]
  messages                     Message[]
  conversationParticipants     ConversationParticipant[]
  privateMessagesSent          PrivateMessage[]
  chatParticipants             ChatParticipant[]
  messageReactions             MessageReaction[]
  messageReadReceipts          MessageReadReceipt[]
  userStatuses                 UserStatus[]
  chatPollVotes                ChatPollVote[]
  createdChatPolls             ChatPoll[]         @relation("ChatPollCreator")
  pinnedConversations          PinnedConversation[]
  chatSearchHistory            ChatSearchHistory[]
  disappearingSettings         DisappearingMessageSetting[]
  chatWallpapers               ChatWallpaper[]

  // Other Relations
  postedJobs                   Job[]              @relation("PostedJobs")
  createdJobs                  Job[]              @relation("CreatedJobs")
  createdBusinesses             Business[]         @relation("BusinessCreator")
  ownedBusinesses               Business[]         @relation("BusinessOwner")
  businessReviews              BusinessReview[]
  events                       Event[]
  eventRSVPs                   EventRSVP[]
  submittedPlaces              CommunityPlace[]   @relation("SubmittedPlaces")
  videos                       Video[]
  videoLikes                   VideoLike[]
  videoComments                VideoComment[]
  alerts                       Alert[]
  alertReads                   AlertRead[]
  adminActions                 AdminAction[]
  bundleVotes                  BundleVote[]
  bundles                      Bundle[]
  marketplaceItems             MarketplaceItem[]
  lostFoundItems               LostFoundItem[]
  reputationLogs               ReputationLog[]
  sosAlerts                    SOSAlert[]
  sosResponses                 SOSResponse[]
  communityPolls               CommunityPoll[]
  communityPollVotes           CommunityPollVote[]

  // New Social Relations
  posts                        Post[]
  postLikes                    PostLike[]
  postComments                 PostComment[]
  commentLikes                 CommentLike[]
  postShares                   PostShare[]
  following                    Follow[]              @relation("Following")
  followers                    Follow[]              @relation("Followers")
  notifications                Notification[]
  savedPosts                   SavedPost[]

  // Skills
  skills                       Skill[]
  skillReviewsReceived         SkillReview[]         @relation("SkillReviewsReceived")
  skillReviewsGiven            SkillReview[]         @relation("SkillReviewsGiven")

  // Harambee
  harambees                    Harambee[]
  harambeeDonations            HarambeeDonation[]

  // Tontine
  tontineGroupsOwned           TontineGroup[]
  tontineMemberships           TontineMember[]
  tontineContributions         TontineContribution[]

  // Loans
  loansGiven                   MicroLoan[]           @relation("LoansGiven")
  loansTaken                   MicroLoan[]           @relation("LoansTaken")

  // Savings
  savingsMemberships           SavingsChallengeMember[]

  // Group Buy
  groupPurchases               GroupPurchase[]
  groupPurchasePledges         GroupPurchasePledge[]

  // Price Watch
  priceReports                 PriceReport[]

  // Errands
  errandsCreated               Errand[]              @relation("ErrandsCreated")
  errandsAccepted              Errand[]              @relation("ErrandsAccepted")

  // Ride Share
  ridesOffered                 RideShare[]           @relation("RidesOffered")
  ridesJoined                  RideShare[]           @relation("RidesJoined")

  // Meal Sharing
  mealShares                   MealShare[]

  // Tool Lending
  toolsListed                  ToolListing[]
  toolBorrows                  ToolBorrow[]

  // Safety
  emergencyContacts            EmergencyContact[]
  safeRoutes                   SafeRoute[]
  checkIns                     ChildCheckIn[]
  missingItems                 MissingPerson[]

  // Social/Cultural
  obituaries                   Obituary[]
  condolences                  Condolence[]
  talents                      TalentShowcase[]
  recipes                      Recipe[]
  photoMemories                PhotoMemory[]
  petitionsCreated             Petition[]
  petitionSignatures           PetitionSignature[]
  parentingPosts               ParentingPost[]

  // Health
  bloodDonor                   BloodDonor?
  moodCheckins                 MentalHealthCheckIn[]

  // Governance
  communityBudgets             CommunityBudget[]
  complaints                   Complaint[]
  complaintComments            ComplaintComment[]
  meetings                     MeetingMinutes[]
  volunteerSignups             VolunteerSignup[]
  volunteerOpportunities       VolunteerOpportunity[]


  @@map("profiles")
}

model ChatRoom {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  type        String      @default("neighborhood")
  zone        String?
  description String?
  avatarUrl   String?     @map("avatar_url")
  createdBy   String?     @map("created_by") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  creator      Profile?           @relation(fields: [createdBy], references: [id])
  messages     Message[]
  participants ChatParticipant[]
  polls        ChatPoll[]

  @@map("chat_rooms")
}

model Message {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId      String   @map("room_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  text        String?
  mediaUrls   Json     @default("[]") @map("media_urls")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  room      ChatRoom         @relation(fields: [roomId], references: [id])
  user      Profile          @relation(fields: [userId], references: [id])
  reactions MessageReaction[]

  @@map("messages")
}

model Job {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String
  description   String
  employerName  String   @map("employer_name")
  location      String
  salaryRange   String?  @map("salary_range")
  jobType       String   @map("job_type")
  contactPhone  String?  @map("contact_phone")
  postedBy      String?  @map("posted_by") @db.Uuid
  createdBy     String?  @map("created_by") @db.Uuid
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  poster  Profile? @relation("PostedJobs", fields: [postedBy], references: [id])
  creator Profile? @relation("CreatedJobs", fields: [createdBy], references: [id])

  @@map("jobs")
}

model Business {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  category     String
  description  String?
  locationLat  Float?   @map("location_lat")
  locationLng  Float?   @map("location_lng")
  phone        String
  openingHours Json?    @map("opening_hours")
  isFeatured   Boolean  @default(false) @map("is_featured")
  photos       Json     @default("[]")
  ownerId      String?  @map("owner_id") @db.Uuid
  createdBy    String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  creator  Profile          @relation("BusinessCreator", fields: [createdBy], references: [id])
  owner    Profile?         @relation("BusinessOwner", fields: [ownerId], references: [id])
  reviews  BusinessReview[]

  @@map("businesses")
}

model BusinessReview {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     Profile  @relation(fields: [userId], references: [id])

  @@unique([businessId, userId])
  @@map("business_reviews")
}

model Event {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String
  description   String?
  date          DateTime @db.Date
  location      String
  category      String
  coverPhoto    String?  @map("cover_photo")
  maxAttendees  Int?     @map("max_attendees")
  isFree        Boolean  @default(true) @map("is_free")
  ticketPrice   Float?   @map("ticket_price")
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  creator Profile    @relation(fields: [createdBy], references: [id])
  rsvps   EventRSVP[]

  @@map("events")
}

model EventRSVP {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId   String          @map("event_id") @db.Uuid
  userId    String          @map("user_id") @db.Uuid
  status    EventRSVPStatus @default(going)
  createdAt DateTime        @default(now()) @map("created_at")

  // Relations
  event Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  Profile @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("event_rsvps")
}

model CommunityPlace {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  category    String
  description String?
  lat         Float
  lng         Float
  phone       String?
  website     String?
  submittedBy String?  @map("submitted_by") @db.Uuid
  isApproved  Boolean  @default(true) @map("is_approved")
  isOfficial  Boolean  @default(false) @map("is_official")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  submitter Profile? @relation("SubmittedPlaces", fields: [submittedBy], references: [id])

  @@map("community_places")
}

model Video {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  description  String?
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  userId       String   @map("user_id") @db.Uuid
  likesCount   Int      @default(0) @map("likes_count")
  commentsCount Int     @default(0) @map("comments_count")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user     Profile        @relation(fields: [userId], references: [id])
  likes    VideoLike[]
  comments VideoComment[]

  @@map("videos")
}

model VideoLike {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  videoId   String   @map("video_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  video Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user  Profile @relation(fields: [userId], references: [id])

  @@unique([videoId, userId])
  @@map("video_likes")
}

model VideoComment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  videoId   String   @map("video_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  video Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user  Profile @relation(fields: [userId], references: [id])

  @@map("video_comments")
}

// ─── Chat / DM System ─────────────────────────────────

model Conversation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  participants         ConversationParticipant[]
  messages             PrivateMessage[]
  pinnedBy             PinnedConversation[]
  searchHistory        ChatSearchHistory[]
  disappearingSettings DisappearingMessageSetting[]
  chatWallpapers       ChatWallpaper[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  lastReadAt     DateTime? @map("last_read_at")
  isMuted        Boolean   @default(false) @map("is_muted")
  isArchived     Boolean   @default(false) @map("is_archived")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         Profile      @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model PinnedConversation {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         Profile      @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@map("pinned_conversations")
}

model PrivateMessage {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String        @map("conversation_id") @db.Uuid
  senderId       String        @map("sender_id") @db.Uuid
  text           String?
  type           MessageType   @default(text)
  mediaUrl       String?       @map("media_url")
  replyToId      String?       @map("reply_to_id") @db.Uuid
  isStarred      Boolean       @default(false) @map("is_starred")
  isDeleted      Boolean       @default(false) @map("is_deleted")
  isEdited       Boolean       @default(false) @map("is_edited")
  createdAt      DateTime      @default(now()) @map("created_at")
  readAt         DateTime?     @map("read_at")
  expiresAt      DateTime?     @map("expires_at")

  // Relations
  conversation Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Profile                   @relation(fields: [senderId], references: [id])
  replyTo      PrivateMessage?           @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      PrivateMessage[]          @relation("MessageReplies")
  reactions    MessageReaction[]
  readReceipts MessageReadReceipt[]

  @@map("private_messages")
}

model MessageReaction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  emoji           String
  createdAt       DateTime @default(now()) @map("created_at")

  // Polymorphic: either message (group) or privateMessage (DM)
  messageId       String?  @map("message_id") @db.Uuid
  privateMessageId String? @map("private_message_id") @db.Uuid

  // Relations
  user           Profile        @relation(fields: [userId], references: [id])
  message        Message?       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  privateMessage PrivateMessage? @relation(fields: [privateMessageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@unique([userId, privateMessageId])
  @@map("message_reactions")
}

model MessageReadReceipt {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  readAt          DateTime @default(now()) @map("read_at")
  privateMessageId String @map("private_message_id") @db.Uuid

  // Relations
  user           Profile        @relation(fields: [userId], references: [id])
  privateMessage PrivateMessage @relation(fields: [privateMessageId], references: [id], onDelete: Cascade)

  @@unique([userId, privateMessageId])
  @@map("message_read_receipts")
}

model ChatParticipant {
  roomId    String    @map("room_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  joinedAt  DateTime  @default(now()) @map("joined_at")
  isAdmin   Boolean   @default(false) @map("is_admin")

  // Relations
  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user Profile  @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("chat_participants")
}

model ChatPoll {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId      String     @map("room_id") @db.Uuid
  question    String
  options     Json
  status      PollStatus @default(active)
  createdBy   String     @map("created_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  endsAt      DateTime?  @map("ends_at")

  // Relations
  room    ChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  creator Profile         @relation("ChatPollCreator", fields: [createdBy], references: [id])
  votes   ChatPollVote[]

  @@map("chat_polls")
}

model ChatPollVote {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pollId  String   @map("poll_id") @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  option  Int
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  poll ChatPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user Profile @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
  @@map("chat_poll_votes")
}

model UserStatus {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  content   String
  mediaUrl  String?   @map("media_url")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user Profile @relation(fields: [userId], references: [id])

  @@map("user_statuses")
}

model ChatSearchHistory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  query          String
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  user         Profile      @relation(fields: [userId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("chat_search_history")
}

model DisappearingMessageSetting {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String               @map("conversation_id") @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  duration       DisappearingDuration @default(off)
  createdAt      DateTime             @default(now()) @map("created_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         Profile      @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@map("disappearing_message_settings")
}

model ChatWallpaper {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  wallpaperUrl   String   @map("wallpaper_url")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         Profile      @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@map("chat_wallpapers")
}

// ─── Bundles ──────────────────────────────────────────

model Bundle {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider    BundleProvider
  name        String
  price       Float
  dataAmount  String         @map("data_amount")
  validity    String
  category    BundleCategory @default(other)
  url         String?
  description String?
  upvotes     Int            @default(0)
  downvotes   Int            @default(0)
  createdBy   String         @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")

  // Relations
  creator Profile      @relation(fields: [createdBy], references: [id])
  votes   BundleVote[]

  @@map("bundles")
}

model BundleVote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bundleId  String   @map("bundle_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  bundle Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  user   Profile @relation(fields: [userId], references: [id])

  @@unique([bundleId, userId])
  @@map("bundle_votes")
}

// ─── Marketplace ──────────────────────────────────────

model MarketplaceItem {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  price       Float
  category    MarketplaceCategory
  photos      Json                  @default("[]")
  location    String?
  status      MarketplaceItemStatus @default(available)
  sellerId    String                @map("seller_id") @db.Uuid
  createdAt   DateTime              @default(now()) @map("created_at")

  // Relations
  seller Profile @relation(fields: [sellerId], references: [id])

  @@map("marketplace_items")
}

// ─── Lost & Found ─────────────────────────────────────

model LostFoundItem {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  category    String
  location    String?
  photo       String?
  type        LostFoundType
  status      LostFoundStatus @default(active)
